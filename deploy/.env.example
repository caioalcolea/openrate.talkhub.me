# ============================================================================
# OpenRate — variáveis de ambiente da stack Swarm "openrate"
# ----------------------------------------------------------------------------
# Estas variáveis são preenchidas na tela de deploy do Portainer
# (Stacks -> Add stack -> Environment variables) e interpoladas no
# deploy/openrate.yaml via ${VARIAVEL}.
#
# NUNCA commitar valores reais. Este arquivo contém apenas placeholders.
# ============================================================================

# ----------------------------------------------------------------------------
# BANCO DE DADOS (Postgres compartilhado do servidor — container supabase_db:5432, schema "openrate")
# ----------------------------------------------------------------------------
# Senha da role de RUNTIME "openrate_app" criada no runbook (passo 3).
# A role é NOSUPERUSER/NOBYPASSRLS, NÃO é dona de nenhum objeto (o dono do
# schema é a role de migração "openrate_owner"), restrita ao schema "openrate",
# com search_path=openrate definido no nível da role.
OPENRATE_DB_PASSWORD=troque-por-uma-senha-forte-de-32-chars

# ----------------------------------------------------------------------------
# REDIS DEDICADO (openrate_redis — BullMQ)
# ----------------------------------------------------------------------------
# Senha do requirepass do Redis dedicado da stack. Sem senha, qualquer container
# da rede compartilhada talkhub poderia conectar e executar FLUSHALL nas filas.
OPENRATE_REDIS_PASSWORD=troque-por-uma-senha-forte-de-32-chars

# ----------------------------------------------------------------------------
# AUTH (JWT próprio da API)
# ----------------------------------------------------------------------------
# Segredo HS256 com que a API assina E valida o próprio JWT. Gere um valor forte
# e aleatório (ex.: openssl rand -hex 32). MÍNIMO 32 caracteres (a API recusa subir
# em produção com segredo curto/padrão).
JWT_SECRET=troque-por-um-segredo-hs256-forte-e-aleatorio

# Token que libera a criação do 1º super_admin (POST /v1/auth/bootstrap, header
# x-bootstrap-token). SEM ele o endpoint fica desabilitado (fail-closed) — impede
# que um anônimo tome o super_admin na janela de deploy. Gere: openssl rand -hex 24.
BOOTSTRAP_TOKEN=troque-por-um-token-de-bootstrap-forte

# ----------------------------------------------------------------------------
# S3 / MINIO (MinIO reaproveitado — bucket dedicado "openrate-media")
# ----------------------------------------------------------------------------
# Credenciais do usuário DEDICADO "openrate-app" criado no MinIO (runbook passo 4).
# NÃO usar o root user (Admin) — a policy do usuário dedicado dá acesso apenas
# ao bucket openrate-media.
S3_ACCESS_KEY=openrate-app
S3_SECRET_KEY=troque-por-uma-secret-key-forte

# Observação: S3_ENDPOINT (http://minio_minio:9000), S3_PUBLIC_ENDPOINT
# (https://bucketss3.talkhub.me), S3_BUCKET (openrate-media) e S3_REGION
# (eu-south) são fixos no openrate.yaml e não precisam ser definidos aqui.

# ----------------------------------------------------------------------------
# IA (Anthropic — geração de ideias/roteiros)
# ----------------------------------------------------------------------------
# Chave da API da Anthropic. Modelos (fixos no yaml):
#   primário claude-sonnet-5 | fallback econômico claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER

# ----------------------------------------------------------------------------
# PAGAMENTOS (Asaas — payout Pix para atendentes)
# ----------------------------------------------------------------------------
# Chave de API do Asaas (produção). Para homologação use a chave do sandbox.
ASAAS_API_KEY=$aact_PLACEHOLDER
# Base URL do Asaas:
#   produção:    https://api.asaas.com/v3
#   homologação: https://api-sandbox.asaas.com/v3
ASAAS_BASE_URL=https://api.asaas.com/v3
# Token que valida o webhook do Asaas (fase Escala; pode ficar vazio no MVP —
# o webhook é stub e o payout é registrado manualmente).
ASAAS_WEBHOOK_TOKEN=

# ----------------------------------------------------------------------------
# DOCUSEAL (termo de cessão — webhook; fase Escala)
# ----------------------------------------------------------------------------
# Token que valida o webhook do Docuseal (pode ficar vazio no MVP).
DOCUSEAL_WEBHOOK_TOKEN=

# ----------------------------------------------------------------------------
# ERP (Olist/Tiny — conector de catálogo/vendas; fase Escala)
# ----------------------------------------------------------------------------
# Chave da API do Olist/Tiny (vazio no MVP — só o worker usa; stub por enquanto).
OLIST_API_KEY=

# ----------------------------------------------------------------------------
# FLAGS DAS INTEGRAÇÕES (fase Escala) — só habilitam os endpoints de disparo na
# API; os SEGREDOS ficam no worker. Deixe "false" no MVP.
# ----------------------------------------------------------------------------
ASAAS_ENABLED=false
OLIST_ENABLED=false
METRICS_SYNC_ENABLED=false

# ----------------------------------------------------------------------------
# WHATSAPP (Evolution API já em produção — evolution_evolution_api:8080)
# ----------------------------------------------------------------------------
# API key global da Evolution API (AUTHENTICATION_API_KEY da stack evolution)
EVOLUTION_API_KEY=troque-pela-api-key-da-evolution
# Nome da instância WhatsApp usada para as notificações do OpenRate
# (meta batida, comissão creditada, vídeo aprovado)
EVOLUTION_INSTANCE=openrate

# ----------------------------------------------------------------------------
# FILAS / BULL BOARD (openrate-queues.talkhub.me)
# ----------------------------------------------------------------------------
# Usuário:hash bcrypt para o middleware basicauth do Traefik.
# Gerar com: htpasswd -nbB openrate 'SUA_SENHA' (runbook passo 6).
# ENVOLVA EM ASPAS SIMPLES: o hash tem '$' e o first-up.sh faz `source .env` —
# sem aspas o shell corrompe o valor. (No Portainer, cole o hash CRU, sem aspas.)
BULLBOARD_BASICAUTH='openrate:$2y$05$PLACEHOLDERPLACEHOLDERPLACEHOLDERPLACEHOLD'
# Basic auth de APLICAÇÃO do Bull Board (2ª camada, defesa em profundidade além do
# Traefik — protege contra acesso leste-oeste na overlay). Senha em texto puro.
BULLBOARD_USER=openrate
BULLBOARD_PASSWORD=troque-por-uma-senha-forte

# ----------------------------------------------------------------------------
# PROVISIONAMENTO (usado SOMENTE pelo deploy/first-up.sh; NÃO vai para a stack)
# ----------------------------------------------------------------------------
# Senha da role de MIGRAÇÃO openrate_owner (dona do schema). Diferente da app.
OPENRATE_DB_OWNER_PASSWORD=troque-por-outra-senha-forte
# Credenciais ROOT do MinIO (para o first-up.sh criar bucket/usuário/policy).
# São as MINIO_ROOT_USER/PASSWORD da stack minio já em produção.
MINIO_ROOT_USER=Admin
MINIO_ROOT_PASSWORD=troque-pela-senha-root-do-minio
# Senha do usuário postgres do container do banco (supabase_db) — usada pelo
# first-up.sh para criar as roles e aplicar as migrations. É a POSTGRES_PASSWORD
# da stack de banco do servidor.
DB_SUPERUSER_PASSWORD=troque-pela-senha-postgres-do-banco

# ----------------------------------------------------------------------------
# MISC
# ----------------------------------------------------------------------------
# IMPORTANTE: as senhas acima entram em URLs (DATABASE_URL, REDIS_URL) e no
# --requirepass do Redis — use apenas caracteres alfanuméricos (evite @ : / #)
# para não quebrar a interpolação.
# TZ=America/Sao_Paulo já é fixo no yaml em todos os serviços.
# REDIS_URL=redis://:${OPENRATE_REDIS_PASSWORD}@openrate_redis:6379 é montado no
# yaml (Redis dedicado da stack; o alias "openrate_redis" vem da chave de serviço
# já prefixada no compose e resolve independente do nome da stack no Portainer —
# NUNCA apontar para o global redis_redis).
