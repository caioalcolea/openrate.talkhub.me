# ============================================================================
# OpenRate — variáveis para desenvolvimento LOCAL (docker-compose.dev.yml)
# Copie para .env.dev e ajuste. NUNCA commitar segredos reais.
# Para produção (stack Swarm), ver deploy/.env.example.
# ============================================================================

# Banco local (o compose sobe um Postgres 15 dedicado ao dev)
OPENRATE_DB_PASSWORD=dev_openrate
DATABASE_URL=postgresql://openrate_app:dev_openrate@db:5432/openrate

# Redis local (o compose sobe um redis:7-alpine)
REDIS_URL=redis://redis:6379

# Auth — em dev, usar um segredo HS256 qualquer e emitir JWTs de teste.
JWT_SECRET=dev-super-secret-hs256-change-me
# Token exigido por POST /v1/auth/bootstrap (header x-bootstrap-token) — fail-closed
# mesmo em dev. Use este valor ao criar o 1º super_admin localmente.
BOOTSTRAP_TOKEN=dev-bootstrap-token

# Storage — MinIO local do compose
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=openrate-media
S3_REGION=eu-south
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# IA
ANTHROPIC_API_KEY=sk-ant-dev-placeholder
AI_MODEL_PRIMARY=claude-sonnet-5
AI_MODEL_FALLBACK=claude-haiku-4-5

# Integrações externas (opcionais em dev — deixe vazio para desabilitar)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=openrate
BROWSERLESS_URL=

# Worker
WHISPER_MODEL=small
